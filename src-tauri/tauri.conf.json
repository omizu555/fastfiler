{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FastFiler",
  "version": "0.1.0",
  "identifier": "dev.omiz.fastfiler",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FastFiler",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 400,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
